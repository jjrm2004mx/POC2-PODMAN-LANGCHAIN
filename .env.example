# =============================================================================
# OBSERVABILIDAD — LangSmith (Trazabilidad del Agente)
# Obtener claves en: https://smith.langchain.com → Settings → API Keys
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=tu-langsmith-api-key
LANGCHAIN_PROJECT=shared-services-classifier-dev

# =============================================================================
# PROVEEDOR DE IA — Configurable en Runtime
# Valores: ollama | openai | anthropic | gemini
# =============================================================================
AGENT_PROVIDER=ollama
AGENT_MAX_ITERATIONS=5
VALIDATION_ENABLED=true
AGENT_DOMAINS=IT,cliente,operaciones,otro

# Categorías permitidas por dominio (separadas por coma)
CATEGORIES_IT=hardware,software,red,acceso,correo,impresora,vpn,servidor,base_de_datos,seguridad
CATEGORIES_CLIENTE=facturacion,reclamo,consulta,devolucion,garantia,soporte,pedido,envio
CATEGORIES_OPERACIONES=logistica,compras,inventario,mantenimiento,produccion,calidad,proveedores
CATEGORIES_OTRO=general,sin_clasificar

# Umbral de similitud para fuzzy matching (0-100, default 80)
FUZZY_THRESHOLD=80
# Confianza mínima aceptable (0.0-1.0). Por debajo → reintenta clasificación
MIN_CONFIDENCE=0.7
# Timeout de llamadas al LLM en segundos (classify + enrich)
# 7 min — ajustar según modelo y entorno
LLM_TIMEOUT=3600
# 15 min — enriquecimiento de hilo (suele tardar más)
ENRICH_LLM_TIMEOUT=3600

# =============================================================================
# OLLAMA — LLM Local (no requiere API key)
# Modelo: llama3:latest (13GB) o llama3.2:3b (2GB)
# URL accesible desde contenedor: http://ollama:11434
# =============================================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=tu-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# ANTHROPIC
# =============================================================================
ANTHROPIC_API_KEY=tu-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# =============================================================================
# GOOGLE GEMINI
# =============================================================================
GEMINI_API_KEY=tu-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# =============================================================================
# BASE DE DATOS — PostgreSQL
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=classifier-db
POSTGRES_PORT=5432
POSTGRES_DB=classifier_db

# =============================================================================
# CACHE — Redis
# =============================================================================
REDIS_HOST=classifier-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# ticket-management-backend — Integración externa
# Escenario A (WSL): TICKET_MGMT_API_URL=http://<IP-Windows>:8080/api/v1
# Escenario B (shared-network): TICKET_MGMT_API_URL=http://ticket-system-backend:8080/api/v1
# =============================================================================
TICKET_MGMT_API_URL=http://ticket-system-backend:8080/api/v1
# Debe coincidir con INTERNAL_API_KEY de ticket-management. Generar con: openssl rand -base64 32
#TICKET_MGMT_API_URL=http://172.20.208.1:8080/api/v1
TICKET_MGMT_API_KEY=reemplazar_con_secreto_real
TICKET_MGMT_CATALOGO_ENABLED=true

# =============================================================================
# MINIO — Almacenamiento de adjuntos
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=email-attachments

# =============================================================================
#  Modo mock: salta el LLM y usa clasificación fija (solo para desarrollo/pruebas)
#  AGENT_MOCK_CLASSIFY=true
# =============================================================================
AGENT_MOCK_CLASSIFY=false
MOCK_DOMINIO=IT
MOCK_CATEGORIA=acceso
MOCK_PRIORIDAD=BAJA
MOCK_CONFIANZA=1.0
