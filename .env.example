# =============================================================================
# shared-services-classifier — Variables de entorno
# Copiar este archivo a .env y completar los valores requeridos.
# Los valores con :-default en docker-compose.yml son opcionales aquí.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS — PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=ai

# -----------------------------------------------------------------------------
# AGENTE — Clasificador LangGraph
# -----------------------------------------------------------------------------
AGENT_PROVIDER=ollama                          # ollama | openai | anthropic | gemini
AGENT_MAX_ITERATIONS=5
AGENT_DOMAINS=IT,cliente,operaciones,otro
VALIDATION_ENABLED=true
FUZZY_THRESHOLD=80
MIN_CONFIDENCE=0.7

# Timeout de llamadas al LLM en segundos (classify + enrich)
LLM_TIMEOUT=420                                # 7 min — ajustar según modelo y entorno
ENRICH_LLM_TIMEOUT=900                         # 15 min — enriquecimiento de hilo (suele tardar más)

# -----------------------------------------------------------------------------
# CATEGORÍAS POR DOMINIO (separadas por coma)
# Si no se definen, el agente usa texto libre.
# -----------------------------------------------------------------------------
CATEGORIES_IT=
CATEGORIES_CLIENTE=
CATEGORIES_OPERACIONES=
CATEGORIES_OTRO=

# -----------------------------------------------------------------------------
# MODELOS — Ollama (local)
# -----------------------------------------------------------------------------
OLLAMA_MODEL=llama3.2:3b

# -----------------------------------------------------------------------------
# MODELOS — OpenAI (opcional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# MODELOS — Anthropic (opcional)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# -----------------------------------------------------------------------------
# MODELOS — Gemini (opcional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# SHARED SERVICES — Correo corporativo oficial
# -----------------------------------------------------------------------------
SS_EMAIL=                                      # Requerido — correo oficial de Shared Services (ej: ss@empresa.com)

# -----------------------------------------------------------------------------
# TICKET MANAGEMENT BACKEND
# -----------------------------------------------------------------------------
TICKET_MGMT_API_URL=                           # Requerido — URL base del backend
TICKET_MGMT_API_KEY=change-this-secret-key-in-production
TICKET_MGMT_CATALOGO_ENABLED=true

# -----------------------------------------------------------------------------
# ALMACENAMIENTO — MinIO
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=email-attachments

# -----------------------------------------------------------------------------
# OBSERVABILIDAD — LangSmith (opcional)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shared-services-classifier-dev

# -----------------------------------------------------------------------------
# OBSERVABILIDAD — Grafana
# -----------------------------------------------------------------------------
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# MOCK — Solo para desarrollo/pruebas
# -----------------------------------------------------------------------------
AGENT_MOCK_CLASSIFY=false
AGENT_PREPROCESS_EMAIL=false   # true = pre-procesa el cuerpo antes de enviarlo al LLM (recomendado para modelos locales Ollama)
MOCK_DOMINIO=IT
MOCK_CATEGORIA=acceso
MOCK_PRIORIDAD=BAJA
MOCK_CONFIANZA=1.0
