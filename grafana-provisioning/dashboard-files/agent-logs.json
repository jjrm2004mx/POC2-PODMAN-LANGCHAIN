      "targets": [
        {
          "expr": "{container_name=\"langchain-api\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 3,
      "title": "Errores — todos los contenedores",
